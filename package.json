    "@types/node": "^25.2.3",
    "dotenv": "^17.2.4",
    "tsx": "^4.20.6",
    "turbo": "^2.5.4",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18",
    "zod": "^4.3.6"
  },
  "packageManager": "pnpm@10.14.0"
}
